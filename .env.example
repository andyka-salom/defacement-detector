# ─────────────────────────────────────────────────────────────
# KONFIGURASI SISTEM DETEKSI WEB DEFACEMENT
# Arsitektur: 1 VPS Ubuntu — Nginx + Python + PostgreSQL
# Lokasi project: /var/www/defacement-detector
# Salin: cp .env.example .env && nano .env
# ─────────────────────────────────────────────────────────────

# ── Log Nginx (path lokal di VPS) ────────────────────────────
LOG_PATH=/var/log/nginx/hs_access.log

# ── Target Website ────────────────────────────────────────────
TARGET_BASE_URL=https://x.com

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=defacement_db
DB_USER=deploy_user
DB_PASSWORD=password_anda_170401@

# ── Fonnte WhatsApp API ───────────────────────────────────────
FONNTE_TOKEN=your_fonnte_token_here
WA_TARGET=628xxxxxxxxxx

# ── Deteksi ───────────────────────────────────────────────────
FLUSH_INTERVAL=60
CONTAMINATION=0.10
CONFIDENCE_MEDIUM=50
CONFIDENCE_HIGH=80

# ── Flask Dashboard ───────────────────────────────────────────
FLASK_SECRET_KEY=ganti_dengan_random_string_aman
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# ── Log Sistem ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/system.log
