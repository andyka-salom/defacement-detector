# ─────────────────────────────────────────────────────────────
# KONFIGURASI SISTEM DETEKSI WEB DEFACEMENT
# Arsitektur: 1 VPS Ubuntu — Nginx + Python + PostgreSQL
# Salin file ini menjadi .env lalu isi nilainya:
#   cp .env.example .env && nano .env
# ─────────────────────────────────────────────────────────────

# ── Log Nginx (path lokal di VPS) ────────────────────────────
# Pastikan user menjalankan service punya izin baca file ini.
# Jika tidak: sudo usermod -aG adm $USER  (lalu re-login)
LOG_PATH=/var/log/nginx/access.log

# ── Target Website ────────────────────────────────────────────
TARGET_BASE_URL=https://x.com

# ── PostgreSQL ────────────────────────────────────────────────
# Database harus sudah dibuat terlebih dahulu:
#   sudo -u postgres createdb defacement_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=defacement_db
DB_USER=postgres
DB_PASSWORD=ganti_dengan_password_aman

# ── Fonnte WhatsApp API ───────────────────────────────────────
FONNTE_TOKEN=your_fonnte_token_here
WA_TARGET=628xxxxxxxxxx

# ── Deteksi ───────────────────────────────────────────────────
FLUSH_INTERVAL=60
CONTAMINATION=0.10
CONFIDENCE_MEDIUM=50
CONFIDENCE_HIGH=80

# ── Flask Dashboard ───────────────────────────────────────────
FLASK_SECRET_KEY=ganti_dengan_random_string_aman
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# ── Log Sistem ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/system.log
